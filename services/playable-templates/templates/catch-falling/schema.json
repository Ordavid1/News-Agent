{
  "templateName": "Catch the Falling Items",
  "description": "Products and logos fall from the top. Players drag a basket to catch them. Missed items shatter on the ground. Progressive difficulty.",
  "sections": {
    "colors": {
      "description": "Brand color palette for all visuals",
      "type": "object",
      "required": true,
      "properties": {
        "primary":    { "type": "string", "required": true, "pattern": "^#[0-9A-Fa-f]{6}$", "description": "Main brand color for UI and basket" },
        "secondary":  { "type": "string", "required": true, "pattern": "^#[0-9A-Fa-f]{6}$", "description": "Text and secondary elements" },
        "accent":     { "type": "string", "required": true, "pattern": "^#[0-9A-Fa-f]{6}$", "description": "Highlights, score flashes, particles" },
        "background": { "type": "string", "required": true, "pattern": "^#[0-9A-Fa-f]{6}$", "description": "Scene background base color" }
      }
    },
    "texts": {
      "description": "All user-facing text strings",
      "type": "object",
      "required": true,
      "properties": {
        "title":          { "type": "string", "required": true, "maxLength": 30, "description": "Game title on splash screen" },
        "subtitle":       { "type": "string", "maxLength": 50, "description": "Subtitle or tagline" },
        "cta":            { "type": "string", "required": true, "maxLength": 20, "description": "CTA button text" },
        "scoreLabel":     { "type": "string", "maxLength": 15, "description": "Label above score number" },
        "encouragement":  { "type": "array", "maxItems": 5, "description": "Random encouragement messages on catch" },
        "gameOver":       { "type": "string", "maxLength": 20, "description": "Game over headline" },
        "playAgain":      { "type": "string", "maxLength": 15, "description": "Play again button text" }
      }
    },
    "gameplay": {
      "description": "Core gameplay tuning parameters",
      "type": "object",
      "required": true,
      "properties": {
        "duration":       { "type": "number", "required": true, "min": 20, "max": 120, "description": "Game duration in seconds" },
        "spawnRate":      { "type": "number", "min": 300, "max": 2000, "description": "Initial ms between item spawns" },
        "fallSpeedMin":   { "type": "number", "min": 50, "max": 300, "description": "Minimum fall speed (px/s)" },
        "fallSpeedMax":   { "type": "number", "min": 100, "max": 500, "description": "Maximum fall speed (px/s)" },
        "pointsPerCatch": { "type": "number", "min": 1, "max": 100, "description": "Points awarded per catch" },
        "missLimit":      { "type": "number", "min": 0, "max": 20, "description": "Max misses before game over (0 = no limit)" }
      }
    },
    "assets": {
      "description": "Mapping of brand assets to game roles",
      "type": "object",
      "properties": {
        "collectibles":   { "type": "array", "maxItems": 5, "description": "Asset keys for falling items (e.g., ['sprite_0', 'sprite_1'])" },
        "logo":           { "type": "string", "description": "Asset key for brand logo on splash/end screen" }
      }
    },
    "difficulty": {
      "description": "Difficulty ramp parameters",
      "type": "object",
      "properties": {
        "rampInterval":       { "type": "number", "min": 5, "max": 30, "description": "Seconds between difficulty increases" },
        "speedMultiplier":    { "type": "number", "min": 1.0, "max": 2.0, "description": "Fall speed multiplier per ramp" },
        "spawnRateDecrease":  { "type": "number", "min": 0, "max": 200, "description": "ms decrease in spawn rate per ramp" }
      }
    },
    "theme": {
      "description": "Visual theme options",
      "type": "object",
      "properties": {
        "backgroundStyle":  { "type": "string", "enum": ["gradient_shift", "floating_shapes", "parallax", "solid"], "description": "Background animation style" },
        "particleDensity":  { "type": "string", "enum": ["low", "medium", "high"], "description": "Ambient particle density" },
        "transitionStyle":  { "type": "string", "enum": ["cinematic_fade", "wipe", "zoom", "flash"], "description": "Scene transition style" }
      }
    }
  }
}
